<Window x:Class="HtmlToDesktopConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HTML to Desktop Converter" Height="700" Width="1200"
        Background="#0b0f14" Foreground="#e7edf5"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#101723" BorderBrush="#1f2c3d" BorderThickness="0,0,0,1">
            <StackPanel Padding="20" Orientation="Vertical" Gap="10">
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#ffb454">
                    🎨 HTML to Desktop Converter
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#7e8da3">
                    حول أي ملف HTML/JSON إلى تطبيق سطح مكتب احترافي
                </TextBlock>

                <StackPanel Orientation="Horizontal" Gap="10" Margin="0,10,0,0">
                    <TextBlock Text="مسار الملف:" VerticalAlignment="Center" Foreground="#7e8da3"/>
                    <TextBox x:Name="FilePath" Width="300" Padding="8" 
                             Background="#0a0f17" Foreground="#e7edf5" BorderBrush="#1f2c3d" BorderThickness="1"/>
                    <Button Content="📂 استعرض" Click="BrowseFile_Click" 
                            Background="#ffb454" Foreground="#1a1305" Padding="12,6" FontWeight="Bold"/>
                    <Button Content="⚙ تحويل وتشغيل" Click="Convert_Click" 
                            Background="#5ac8fa" Foreground="#ffffff" Padding="12,6" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Gap="20" Margin="0,10,0,0">
                    <CheckBox x:Name="ConnectDB" Content="ربط قاعدة البيانات" IsChecked="True" Foreground="#e7edf5"/>
                    <CheckBox x:Name="LoadONNX" Content="تحميل نموذج ONNX" IsChecked="False" Foreground="#e7edf5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- WebView2 -->
        <Grid Grid.Row="1" Background="#0b0f14">
            <WebView2 x:Name="WebView" Margin="0"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#101723" BorderBrush="#1f2c3d" BorderThickness="0,1,0,0">
            <StackPanel Padding="20" Orientation="Horizontal" Gap="20">
                <TextBlock x:Name="StatusText" Text="جاهز" Foreground="#7e8da3" FontSize="12"/>
                <TextBlock x:Name="FileInfoText" Text="لم يتم اختيار ملف" Foreground="#7e8da3" FontSize="12"/>
                <TextBlock x:Name="DBStatusText" Text="قاعدة البيانات: غير متصلة" Foreground="#ff3b30" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>